{
  "id": "doodle-sketch",
  "name": "Doodle Sketch",
  "preview": "preview.svg",
  "version": "1.0.0",
  "description": "Giao diện phác thảo tay — viền nét, bóng offset và nền kem ấm (themeskill/theme1).",
  "themeTokens": {
    "typography": {
      "fontFamily": "Delius Swash Caps",
      "displayFont": "Delius Swash Caps",
      "bodyFont": "Delius Swash Caps"
    },
    "effects": {
      "backgroundEffectClassName": "theme-surface-doodle",
      "backgroundEffectCss": "",
      "interactionCss": ".theme-surface-doodle .phone-content-card { transition: transform 180ms ease, box-shadow 180ms ease; } .theme-surface-doodle .phone-content-card:hover { transform: translate(-2px, -2px) rotate(-0.6deg); }"
    },
    "review": { "fontSize": 15 }
  },
  "cssDefaults": {
    "colors": {
      "headerTextAndIcon": "#1F2937",
      "socialBlockBackground": "#EFEBE1",
      "socialBlockText": "#1F2937",
      "contentBlockBackground": "#F9F6F0",
      "contentBlockText": "#6B7280",
      "contentBlockButton": "#EACDC2"
    },
    "divLayout": {
      "widthPercent": 92,
      "border": { "width": 3, "style": "solid", "color": "#111827", "radius": 18 },
      "boxShadow": { "enabled": true, "x": 4, "y": 4, "blur": 0, "spread": 0, "color": "#111827" }
    },
    "typography": { "fontFamily": "Delius Swash Caps" }
  },
  "fields": [
    { "key": "typography.fontFamily", "type": "font-select", "label": "Font chữ", "options": ["Delius Swash Caps", "Inter", "Roboto", "Poppins", "Montserrat", "Lora", "Playfair Display", "Noto Sans", "System"] },
    { "key": "divLayout.widthPercent", "type": "number", "label": "Chiều ngang (%)" },
    { "key": "divLayout.border.width", "type": "number", "label": "Chiều rộng border (px)" },
    { "key": "divLayout.border.color", "type": "color", "label": "Màu border" },
    { "key": "divLayout.border.radius", "type": "number", "label": "Border radius" },
    { "key": "divLayout.boxShadow.enabled", "type": "boolean", "label": "Shadow mặc định theo theme" },
    { "key": "colors.headerTextAndIcon", "type": "color", "label": "Tiêu đề & biểu tượng" },
    { "key": "colors.socialBlockBackground", "type": "color", "label": "Nền khối social" },
    { "key": "colors.socialBlockText", "type": "color", "label": "Chữ khối social" },
    { "key": "colors.contentBlockBackground", "type": "color", "label": "Nền khối nội dung" },
    { "key": "colors.contentBlockText", "type": "color", "label": "Chữ khối nội dung" },
    { "key": "colors.contentBlockButton", "type": "color", "label": "Màu nút / accent" }
  ],
  "layout": "single-column"
}
